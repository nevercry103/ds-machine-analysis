//
// Machine: {{ machine_name }}
// Steps:   {{ total_steps }}
//
// Handshake (per TEMPLATE_STANDARD.md):
//   1. PLC sets {{ cycle_ready_tag }} = TRUE when cycle completes.
//   2. Python reads {{ cycle_log_tag }} (UDT_CycleLog).
//   3. Python sets {{ cycle_reset_tag }} = TRUE.
//   4. PLC clears both flags and arms for the next cycle.
//
// Timestamp is read at PLC via RD_SYS_T() — never on Python side.
// This is what guarantees the <=10 ms cycle-time accuracy DS Machine
// Analyzer commits to.
// =====================================================================

TYPE "UDT_StepLog"
VERSION : 0.1
    STRUCT
        step_index      : INT;
        step_name       : STRING[32];
        timestamp_start : DTL;
        timestamp_end   : DTL;
        duration_ms     : DINT;
        status          : INT;       // 0=waiting 1=active 2=completed 3=failed
    END_STRUCT;
END_TYPE

TYPE "UDT_CycleLog"
VERSION : 0.1
    STRUCT
        cycle_id          : DINT;
        timestamp_start   : DTL;
        timestamp_end     : DTL;
        total_duration_ms : DINT;
        status            : INT;     // 0=idle 1=running 2=completed 3=aborted
        step_count        : INT := {{ total_steps }};
        steps             : ARRAY[1..{{ total_steps }}] OF "UDT_StepLog";
    END_STRUCT;
END_TYPE

FUNCTION_BLOCK "FB_CycleMaster"
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1
    VAR_INPUT
        // Edge-triggered inputs from caller — one pair per step.
{%- for step in steps %}
        StepStart_{{ step.index }} : BOOL;   // {{ step.name }}
        StepEnd_{{ step.index }}   : BOOL;   // {{ step.name }}
{%- endfor %}
        CycleAbort : BOOL;
    END_VAR

    VAR_IN_OUT
        {{ cycle_reset_tag }} : BOOL;        // Python sets TRUE to ack
    END_VAR

    VAR_OUTPUT
        {{ cycle_ready_tag }} : BOOL;        // TRUE => cycle data ready
        {{ cycle_log_tag }}   : "UDT_CycleLog";
    END_VAR

    VAR
        _state              : INT := 0;      // 0=idle 1=in_cycle 2=ready 3=ack_wait
        _cycle_counter      : DINT := 0;
        _current_step       : INT := 0;
        _step_start_time    : DTL;
        _cycle_start_time   : DTL;
        _now                : DTL;
        _td_step            : TIME;
        _td_cycle           : TIME;
{%- for step in steps %}
        _prev_StepStart_{{ step.index }} : BOOL;
        _prev_StepEnd_{{ step.index }}   : BOOL;
{%- endfor %}
    END_VAR

BEGIN
    // ---------------------------------------------------------------
    // Acquire current PLC system time. RD_SYS_T() is the canonical
    // Siemens call for high-precision timestamps. DO NOT replace with
    // a Python-side timestamp — that destroys the accuracy guarantee.
    // ---------------------------------------------------------------
    RD_SYS_T(OUT := #_now);

    CASE #_state OF

        0:  // ---------- IDLE: wait for first StepStart edge -----------
            #{{ cycle_ready_tag }} := FALSE;
{%- for step in steps %}
            IF #StepStart_{{ step.index }} AND NOT #_prev_StepStart_{{ step.index }} THEN
                #_cycle_counter := #_cycle_counter + 1;
                #_cycle_start_time := #_now;
                #_step_start_time := #_now;
                #_current_step := {{ step.index }};
                #{{ cycle_log_tag }}.cycle_id := #_cycle_counter;
                #{{ cycle_log_tag }}.timestamp_start := #_now;
                #{{ cycle_log_tag }}.status := 1;  // running
                #{{ cycle_log_tag }}.steps[{{ step.index }}].step_index := {{ step.index }};
                #{{ cycle_log_tag }}.steps[{{ step.index }}].step_name := '{{ step.name }}';
                #{{ cycle_log_tag }}.steps[{{ step.index }}].timestamp_start := #_now;
                #{{ cycle_log_tag }}.steps[{{ step.index }}].status := 1;
                #_state := 1;
            END_IF;
{%- endfor %}

        1:  // ---------- IN_CYCLE: capture step transitions ------------
            // End of current step
{%- for step in steps %}
            IF #StepEnd_{{ step.index }} AND NOT #_prev_StepEnd_{{ step.index }} AND #_current_step = {{ step.index }} THEN
                #_td_step := SUB_TIME(#_now, #_step_start_time);
                #{{ cycle_log_tag }}.steps[{{ step.index }}].timestamp_end := #_now;
                #{{ cycle_log_tag }}.steps[{{ step.index }}].duration_ms := DINT_TO_DINT(TIME_TO_DINT(#_td_step));
                #{{ cycle_log_tag }}.steps[{{ step.index }}].status := 2;  // completed
{%- if step.index < total_steps %}
                #_current_step := {{ step.index + 1 }};
                #_step_start_time := #_now;
                #{{ cycle_log_tag }}.steps[{{ step.index + 1 }}].step_index := {{ step.index + 1 }};
                #{{ cycle_log_tag }}.steps[{{ step.index + 1 }}].step_name := '{{ steps[step.index].name }}';
                #{{ cycle_log_tag }}.steps[{{ step.index + 1 }}].timestamp_start := #_now;
                #{{ cycle_log_tag }}.steps[{{ step.index + 1 }}].status := 1;
{%- else %}
                // Last step — finalize cycle and signal ready.
                #{{ cycle_log_tag }}.timestamp_end := #_now;
                #_td_cycle := SUB_TIME(#_now, #_cycle_start_time);
                #{{ cycle_log_tag }}.total_duration_ms := DINT_TO_DINT(TIME_TO_DINT(#_td_cycle));
                #{{ cycle_log_tag }}.status := 2;  // completed
                #{{ cycle_ready_tag }} := TRUE;
                #_state := 2;
{%- endif %}
            END_IF;
{%- endfor %}

            // Abort on operator request
            IF #CycleAbort THEN
                #{{ cycle_log_tag }}.timestamp_end := #_now;
                #{{ cycle_log_tag }}.status := 3;  // aborted
                #{{ cycle_ready_tag }} := TRUE;
                #_state := 2;
            END_IF;

        2:  // ---------- READY: hold flag until Python acks -----------
            IF #{{ cycle_reset_tag }} THEN
                #_state := 3;
            END_IF;

        3:  // ---------- ACK_WAIT: clear handshake, return to idle ---
            #{{ cycle_ready_tag }} := FALSE;
            #{{ cycle_reset_tag }} := FALSE;
            #_current_step := 0;
            #_state := 0;

    END_CASE;

    // -------------------- Edge-detection bookkeeping -------------------
{%- for step in steps %}
    #_prev_StepStart_{{ step.index }} := #StepStart_{{ step.index }};
    #_prev_StepEnd_{{ step.index }}   := #StepEnd_{{ step.index }};
{%- endfor %}

